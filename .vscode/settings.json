{
  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoSearchPaths": true,
  "python.analysis.extraPaths": ["backend", "src", "components"],
  "python.analysis.indexing": true,
  "python.analysis.packageIndexDepths": [
    {
      "name": "",
      "depth": 1
    }
  ],
  "python.analysis.diagnosticSeverityOverrides": {
    "reportGeneralTypeIssues": "warning"
  },
  "python.analysis.autoImportCompletions": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.variableTypes": true,
  "python.languageServer": "Pylance",
  "python.analysis.memory.keepLibraryAst": false,
  "python.analysis.gotoDefinitionInStringLiteral": true,
  "python.analysis.enableSupportForNestedVirtualEnvironments": false,
  "python.analysis.stubPath": "",
  "python.analysis.logLevel": "Warning",
  "python.testing.unittestArgs": [
    "-v",
    "-s",
    "./nerdedi",
    "-p",
    "*test*.py"
  ],
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": true,

  "extensions.ignoreRecommendations": true,
  "extensions.disabledExtensions": [
    "blackboxapp.blackboxagent",
    "andrepimenta.claude-code-chat",
    "anthropic.claude-code",
    "block.vscode-mcp-extension",
    "augment.vscode-augment",
    "kisstkondoros.vscode-codemetrics",
    "bradlc.vscode-tailwindcss",
    "stylelint.vscode-stylelint",
    "streetsidesoftware.code-spell-checker"
  ],

  "files.exclude": {
    "**/node_modules": true,
    "**/.git": true,
    "**/.DS_Store": true,
    "**/coverage": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true,
    "o3de": true,
    "unity-setup": true,
    "assets/images-optimized": true,
    "assets/images-webp": true,
    "test-results": true
  },

  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/o3de/**": true,
    "**/unity-integration/**": true,
    "**/unity-setup/**": true,
    "**/assets/images-optimized/**": true,
    "**/assets/images-webp/**": true,
    "**/test-results/**": true,
    "**/freespeech/**": true,
    "**/coverage/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true
  },

  "python.analysis.exclude": [
    "**/node_modules/**",
    "**/__pycache__/**",
    "**/build/**",
    ".git/**",
    "coverage/**",
    "dist/**",
    "out/**",
    "assets/images-optimized/**",
    "assets/images-webp/**",
    "frontend/**/node_modules/**",
    "frontend/**/dist/**",
    "frontend/**/build/**",
    "backend/**/node_modules/**",
    "o3de/**",
    "unity-integration/**",
    "unity-setup/**",
    "test-results/**",
    "freespeech/**",
    "cypress/**",
    "playwright/**",
    "frontend/**/cypress/**",
    "frontend/**/playwright/**",
    "frontend/**/tests/**",
    "**/*.min.js",
    "**/*.min.css",
    "**/vendor/**",
    "**/site-packages/**",
    "**/.venv/**",
    "**/env/**",
    "**/.env/**"
  ],

  "python.analysis.include": [
    "src/**/*.py",
    "frontend/**/*.py",
    "backend/**/*.py",
    "components/**/*.py"
  ],

  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/dist": true,
    "**/coverage": true,
    "**/tmp": true,
    "o3de/**": true,
    "unity-setup/**": true,
    "unity-integration/**": true,
    "assets/images-optimized/**": true,
    "assets/images-webp/**": true,
    "**/.git": true,
    "freespeech/**": true
  },

  "github.copilot.advanced": {
    "debug.overrideEngine": "gpt-4",
    "debug.testOverrideProxyUrl": "",
    "debug.overrideProxyUrl": ""
  },

  "github.copilot.enable": {
    "*": true,
    "yaml": true,
    "plaintext": false,
    "markdown": true
  },

  "github.copilot.editor.enableCodeActions": true,
  "github.copilot.editor.enableAutoCompletions": true,

  "github.copilot.chat.localeOverride": "en",
  "github.copilot.chat.scopeSelection": "auto",
  "github.copilot.chat.terminalChatLocation": "quickChat",

  "github.copilot.editor.enableCodeActionGenerations": true,

  "files.associations": {
    "*.code-workspace": "jsonc"
  },

  "claudeCodeChat.permissions.yoloMode": true,
  "security.workspace.trust.enabled": true,
  "security.workspace.trust.startupPrompt": "never",
  "security.workspace.trust.banner": "never",
  "security.workspace.trust.emptyWindow": false,
  "terminal.integrated.enableFileLinks": "on",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "githubPullRequests.fileListLayout": "tree",
  "editor.tabCompletion": "on",
  "shellcheck.enable": true,
  "shellcheck.executablePath": "/usr/bin/shellcheck",
  "shellcheck.run": "onSave",
  "shellcheck.customArgs": [],
  "timonwong.shellcheck.enable": false,

  "search.searchOnType": false,
  "search.searchOnTypeDebouncePeriod": 800,
  "workbench.editor.closeOnFileDelete": true,
  "editor.formatOnSaveMode": "modificationsIfAvailable",
  "editor.suggest.preview": false,
  "editor.inlineSuggest.enabled": true,
  "editor.minimap.enabled": false,
  "workbench.reduceMotion": "on",
  "workbench.enableExperiments": false,
  "telemetry.telemetryLevel": "off",
  "editor.suggest.showWords": false,
  "extensions.autoUpdate": false,
  "extensions.autoCheckUpdates": false,
  "update.mode": "none",
  "terminal.integrated.gpuAcceleration": "off",
  "workbench.list.smoothScrolling": false,
  "editor.smoothScrolling": false,
  "window.menuBarVisibility": "compact",
  "github.copilot.chat.codeGeneration.instructions": [
    {
      "text": "Follow the project's architecture patterns in .github/copilot-instructions.md"
    }
  ]
}
