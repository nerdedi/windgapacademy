{
  "type": "module",
  "name": "windgap-academy",
  "version": "2.0.0",
  "description": "Professional multi-modal learning and gaming platform",
  "private": true,
  "scripts": {
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "build:production": "NODE_ENV=production vite build",
    "build:tailwind": "tailwindcss -i ./src/styles/tailwind.css -o ./src/styles/tailwind.css",
    "start": "node server.js",
    "start:production": "NODE_ENV=production node server.js",
    "dev": "vite --host",
    "dev:debug": "vite --host --debug",
    "preview": "vite preview",
    "preview:production": "vite preview --mode production",
    "lint": "eslint src components pages backend --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src components pages backend --ext .js,.jsx,.ts,.tsx --fix",
    "lint:staged": "lint-staged",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --runInBand --watchAll=false",
    "test:watch": "jest --watch",
    "test:ci": "npx jest --runInBand --color --coverage",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "build:models": "node scripts/build-ai-models.js",
    "optimize:assets": "node scripts/optimize-assets.js",
    "optimize:images": "node scripts/optimize-images.js",
    "analyze:bundle": "npx vite-bundle-analyzer",
    "docker:build": "docker build -t windgap-academy .",
    "docker:run": "docker run -p 3000:3000 windgap-academy",
    "docker:dev": "docker-compose up --build",
    "deploy:staging": "npm run build && npm run deploy:staging:upload",
    "deploy:production": "npm run build:production && npm run deploy:production:upload",
    "health:check": "node scripts/health-check.js",
    "security:audit": "npm audit && npm run security:scan",
    "security:scan": "npx audit-ci --config audit-ci.json",
    "clean": "rm -rf dist node_modules/.cache",
    "clean:all": "rm -rf dist node_modules package-lock.json && npm install",
    "reset": "npm run clean:all && npm run build",
    "precommit": "npm run lint:staged",
    "prepush": "npm run test:ci && npm run e2e",
    "unity:setup": "node scripts/setup-unity.js",
    "unity:test": "echo 'Open http://localhost:3000/unity-builds/test.html to test Unity integration'",
    "unity:copy": "echo 'Copy your Unity WebGL build to public/unity-builds/windgap-academy/'"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "*.{css,scss,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@chakra-ui/react": "^3.27.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@gsap/react": "^2.1.2",
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.0.18",
    "@react-three/cannon": "^6.6.0",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.3.0",
    "@react-three/postprocessing": "^3.0.4",
    "d3": "^7.9.0",
    "express": "^5.1.0",
    "firebase": "^12.2.1",
    "framer-motion": "^12.23.13",
    "gsap": "^3.13.0",
    "helmet": "^8.1.0",
    "howler": "^2.2.4",
    "immer": "^10.1.3",
    "lucide-react": "^0.544.0",
    "morgan": "^1.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.0.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.17.0",
    "react-three-fiber": "^6.0.13",
    "socket.io-client": "^4.7.2",
    "three": "^0.180.0",
    "zustand": "^4.4.4"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@playwright/test": "^1.39.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.8.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/three": "^0.158.3",
    "@typescript-eslint/eslint-plugin": "^6.7.5",
    "@typescript-eslint/parser": "^6.7.5",
    "@vitejs/plugin-react": "^5.0.3",
    "autoprefixer": "^10.4.21",
    "cypress": "^13.4.0",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.1.2",
    "lint-staged": "^15.2.2",
    "markdownlint-cli": "^0.45.0",
    "postcss": "^8.5.6",
    "prettier": "^3.0.3",
    "tailwindcss": "^4.1.13",
    "terser": "^5.44.0",
    "typescript": "^5.2.2",
    "vercel": "^47.1.4",
    "vite": "^5.4.20"
  }
}
