# Server
PORT=5000

# Enhanced Windgap Academy Environment Configuration
# Copy this to .env and fill in your API keys

# ===================
# SERVER CONFIGURATION
# ===================
PORT=5000

# ===================
# AI SERVICE CONFIGURATION
# ===================

# Primary AI Provider (openai, anthropic, local)
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Configuration (alternative)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Local AI Configuration (for self-hosted models)
LOCAL_AI_BASE_URL=http://localhost:11434
LOCAL_AI_MODEL=llama2

# ===================
# FIREBASE CONFIGURATION
# ===================
FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# ===================
# OAUTH CONFIGURATION
# ===================
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=common # Use 'common' for multi-tenant apps

# Apple OAuth
APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY=your_apple_private_key_path

# Facebook OAuth
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret

# ===================
# CURRICULUM BUILDER SETTINGS
# ===================

# Enable advanced features
ENABLE_AI_GENERATION=true
ENABLE_CHARACTER_ANIMATIONS=true
ENABLE_ACCESSIBILITY_FEATURES=true
ENABLE_PERFORMANCE_MONITORING=true

# Default module settings
DEFAULT_MODULE_DURATION=30
DEFAULT_DIFFICULTY=intermediate
DEFAULT_LANGUAGE=en

# Character settings
ENABLE_VOICE_SYNTHESIS=true
DEFAULT_CHARACTER=winnie

# ===================
# ACCESSIBILITY CONFIGURATION
# ===================

# WCAG Compliance Level (A, AA, AAA)
WCAG_LEVEL=AA

# Enable accessibility features
ENABLE_SCREEN_READER_SUPPORT=true
ENABLE_KEYBOARD_NAVIGATION=true
ENABLE_HIGH_CONTRAST=true
ENABLE_LARGE_TEXT=true
ENABLE_AUDIO_DESCRIPTIONS=true

# ===================
# UNITY INTEGRATION
# ===================

# Unity WebGL settings
UNITY_BUILD_PATH=/unity-builds/windgap-academy
ENABLE_UNITY_ANALYTICS=true
UNITY_COMPRESSION=gzip

# Character model settings
CHARACTER_MODEL_PATH=/assets/characters
ENABLE_MODEL_CACHING=true
MODEL_QUALITY=high

# ===================
# BROWSER-USE INTEGRATION
# ===================

# Browser automation settings
BROWSER_USE_API_KEY=your_browser_use_key
ENABLE_BROWSER_AUTOMATION=true

# MCP (Model Context Protocol) Settings
MCP_FILESYSTEM_PATH=/documents
MCP_GITHUB_TOKEN=your_github_token
ENABLE_MCP_INTEGRATION=f

# ===================
# FEATURE FLAGS
# ===================

# Experimental features
ENABLE_EXPERIMENTAL_AI=true
ENABLE_BETA_ANIMATIONS=true
ENABLE_ADVANCED_ACCESSIBILITY=true

# Module features
ENABLE_COLLABORATIVE_EDITING=true
ENABLE_REAL_TIME_COLLABORATION=true
ENABLE_MODULE_SHARING=true

# Assessment features
ENABLE_ADAPTIVE_ASSESSMENTS=true
ENABLE_PEER_REVIEW=false
ENABLE_AUTO_GRADING=true

# Sentry
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Frontend
FRONTEND_URL=http://localhost:3000
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-auth-domain
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-storage-bucket
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id
