# Windgap Academy Environment Configuration
# Minimal configuration for local development

# Server
PORT=5000
FRONTEND_URL=http://localhost:3000

# Firebase (using dummy values for development)
VITE_FIREBASE_API_KEY=dummy-api-key-for-dev
VITE_FIREBASE_AUTH_DOMAIN=windgap-academy-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=windgap-academy-dev
VITE_FIREBASE_STORAGE_BUCKET=windgap-academy-dev.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:1234567890abcdef

# AI Provider (using dummy value for development)
AI_PROVIDER=dummy
OPENAI_API_KEY=dummy-key-for-dev
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# Unity Settings
UNITY_BUILD_PATH=/unity-builds/windgap-academy
ENABLE_UNITY_ANALYTICS=false
UNITY_COMPRESSION=gzip

# Feature Flags
ENABLE_CHARACTER_ANIMATIONS=true
ENABLE_ACCESSIBILITY_FEATURES=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_KEYBOARD_NAVIGATION=true
ENABLE_HIGH_CONTRAST=true
ENABLE_LARGE_TEXT=true
ENABLE_EXPERIMENTAL_AI=true
JWT_SECRET=development-secret-key-for-testing-only
